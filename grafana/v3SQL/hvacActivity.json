          "rawSql": "SELECT \r\n  date_bin($__interval, \"time\") AS \"time\",\r\n  \"${tagName}\" AS \"device_name\", \r\n  AVG(\"value\") AS \"\"\r\nFROM \"temperature\"\r\nWHERE \r\n  \"time\" >= $__timeFrom\r\n  AND \"time\" <= $__timeTo\r\n  AND \"${tagName}\" ~ '^${hvac_temp_Sensors:regex}$'\r\nGROUP BY 1, 2\r\nORDER BY \"time\" ASC",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
