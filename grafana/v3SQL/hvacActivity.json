          "editorMode": "code",
          "format": "time_series",
          "query": "",
          "rawQuery": true,
          "rawSql": "SELECT \r\n  date_bin($__interval, \"time\") AS \"time\",\r\n  '[' || \"${tagName}\" || ']' AS \"field\", -- Replicates your custom bracketed name\r\n  \"value\" AS \"\",\r\n  \"measurement\"\r\nFROM (\r\n  SELECT *, 'coolingSetpoint' AS \"measurement\" FROM \"coolingSetpoint\"\r\n  UNION ALL\r\n  SELECT *, 'heatingSetpoint' AS \"measurement\" FROM \"heatingSetpoint\"\r\n)\r\nWHERE \r\n  \"time\" >= $__timeFrom - interval '1 day'\r\n  AND \"time\" <= $__timeTo\r\n  AND \"${tagName}\" ~ '^${thermostat:regex}$'\r\nGROUP BY 1, 2, 3, 4\r\nORDER BY \"time\" ASC",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ]
          }
        },
        {
          "dataset": "iox",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB3_SQL}"
          },
          "editorMode": "code",
          "format": "time_series",
          "query": "import \"date\"\r\nfrom(bucket: \"${bucket}\")\r\n  |> range(start: date.sub(d: 1d, from: v.timeRangeStart), stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"temperature\")\r\n  |> filter(fn: (r) => r[\"_field\"] == \"value\")\r\n  |> filter(fn: (r) => r[\"${tagName}\"] =~ /^${hvac_temp_Sensors:regex}$/)\r\n  |> map(fn: (r) => ({_value:r._value, _time:r._time, _measurement:r._measurement, _field:\"[\"+r[\"${tagName}\"]+\"]\"}))\r\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "rawQuery": true,
          "rawSql": "SELECT \r\n  date_bin($__interval, \"time\") AS \"time\",\r\n  \"${tagName}\" AS \"_tagName\", \r\n  AVG(\"value\") AS \"_value\"\r\nFROM \"temperature\"\r\nWHERE \r\n  \"time\" >= $__timeFrom\r\n  AND \"time\" <= $__timeTo\r\n  AND \"${tagName}\" ~ '^${hvac_temp_Sensors:regex}$'\r\nGROUP BY 1, 2\r\nORDER BY \"time\" ASC",
          "refId": "B",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ]
          }
        }
      ],
      "title": "HVAC Setpoint with Temperature",
      "type": "timeseries"
