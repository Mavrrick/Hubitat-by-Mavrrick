          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB3_SQL}"
          },
          "editorMode": "code",
          "format": "table",
          "query": "",
          "rawQuery": true,
          "rawSql": "SELECT \r\n  \"state\",\r\n  SUM(\"duration_seconds\")  AS \"total_hours\" -- Converts seconds to decimal hours\r\nFROM (\r\n  SELECT \r\n    \"value\" AS \"state\",\r\n    \"time\",\r\n    -- Calculate the difference between this event and the next one in seconds\r\n    extract(epoch from (LEAD(\"time\") OVER (PARTITION BY \"${tagName}\" ORDER BY \"time\" ASC) - \"time\")) AS \"duration_seconds\"\r\n  FROM \"thermostatOperatingState\"\r\n  WHERE \r\n    \"time\" >= $__timeFrom\r\n    AND \"time\" <= $__timeTo\r\n    AND \"${tagName}\" ~ '^${thermostat:regex}$'\r\n)\r\nWHERE \"duration_seconds\" IS NOT NULL -- Drops the very last point which has no 'next' time\r\nGROUP BY \"state\"\r\nORDER BY \"total_hours\" DESC",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ]
          }
        }
      ],
